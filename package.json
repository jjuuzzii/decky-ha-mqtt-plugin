{
  "name": "decky-mqtt-status",
  "version": "0.6.0",
  "description": "Decky plugin: publishes SteamOS system status, real-time volume, guide-button presses and dock state to MQTT/Home Assistant, with relative volume buttons and remote power control.",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w"
  },
  "keywords": [
    "decky",
    "plugin",
    "steam-deck",
    "mqtt",
    "home-assistant"
  ],
  "author": "Julian",
  "license": "BSD-3-Clause",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@rollup/rollup-linux-x64-musl": "^4.53.3",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
